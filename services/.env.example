# Qually Backend - Environment Variables

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Tatum (Webhooks & RPC Gateway)
# Get your API key at https://dashboard.tatum.io
TATUM_API_KEY=your_tatum_api_key_here
TATUM_WEBHOOK_SECRET=your_webhook_secret_here

# Walrus (Decentralized Storage)
# Testnet endpoints
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=52

# Sui Network
SUI_NETWORK=testnet
QUALLY_PACKAGE_ID=0x8411168d485ebbfadfcae8bed614ef3d4e9d2ac5efc238b908e6851634f12498
TREASURY_OBJECT_ID=0xa0a82717e3823a8eca7af313455aad3caa0832946626bc40568bd3fe8148ffb3

# Webhook URL (must be publicly accessible for Tatum)
# For local development, use a tunneling service:
#   - ngrok:       ngrok http 3000 (then set the ngrok URL)
#   - cloudflared: cloudflared tunnel --url http://localhost:3000
#   - localtunnel: lt --port 3000
# For production, use your deployed server URL
WEBHOOK_URL=http://localhost:3000/webhooks/tatum

# Webhook Security
WEBHOOK_SECRET=qually-webhook-secret

# Email Notifications (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@qually.io
